{
  "manifest_version": 3,
  "name": "DTP_CAAL Accessibility Linter",
  "version": "1.0.0",
  "description": "Context Aware Accessibility Linter powered by AI",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Accessibility Linter"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"]
}
